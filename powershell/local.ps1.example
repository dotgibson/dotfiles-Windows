# ============================================================================
#  local.ps1.example  —  copy to local.ps1 for machine-specific settings.
#  local.ps1 is gitignored. This is where secrets, host-specific paths, and
#  per-machine overrides go — never in the committed layers.
# ============================================================================

# Example: machine-specific PATH addition
# $env:PATH += ';C:\tools\custom'

# Fast-start: skip the heavy prompt/history/completion init in core/10-tools.ps1
# and the update-check startup nudge. The shell still gets aliases + functions,
# just the stock prompt with no starship/zoxide/atuin/carapace.
#
# NOTE: FAST_START is read from the environment when the profile loads, which is
# BEFORE this file (local.ps1 loads last). Setting $env:FAST_START here will NOT
# lighten the current session. Use one of these instead:
#   lean child shell:    $env:FAST_START='1'; pwsh
#   always lean here:    [Environment]::SetEnvironmentVariable('FAST_START','1','User')

# --- Startup speed toggles (set as USER env vars, not here) --------------------
# Read while core/10-tools.ps1 loads, which is BEFORE this file — so set them at
# User scope (persisted, present at next shell start), not in local.ps1.
#
# Terminal-Icons and carapace are OFF by default because they dominate cold start
# (~1.1s and ~1.5s) for features you rarely miss: Terminal-Icons only themes raw
# `Get-ChildItem` (your ls/ll already use eza --icons), and pwsh native completion
# + CompletionPredictor + atuin cover most of what carapace adds. Re-enable either:
#   [Environment]::SetEnvironmentVariable('DOTFILES_TERMINAL_ICONS','1','User')
#   [Environment]::SetEnvironmentVariable('DOTFILES_CARAPACE','1','User')
# Measure with `shell-bench`; see the full per-step breakdown with `prof-trace`.

# --- Optional package groups (U3) ----------------------------------------------
# The first interactive `Install-Packages.ps1` run asks (via gum) which optional
# package groups to install and writes its answer here as DOTFILES_PKG_GROUPS — a
# space-separated list, or 'none'. Later runs reuse it without prompting; edit or
# delete the line to be asked again. Available groups: 'gui' (1Password) and
# 'desktop' (GlazeWM, Zebar, PowerToys, TranslucentTB — the opt-in
# tiling-desktop layer). Non-interactive/CI runs ignore this and install every group.
#   $env:DOTFILES_PKG_GROUPS = 'gui desktop'

# Example: per-host proxy
# $env:HTTP_PROXY  = 'http://127.0.0.1:8080'
# $env:HTTPS_PROXY = 'http://127.0.0.1:8080'

# Example: override the default WSL distro for the bridge functions
# function kali { wsl -d kali-linux @args }

# Example: a machine-specific alias
# function work { Set-Location 'C:\path\to\project' }
