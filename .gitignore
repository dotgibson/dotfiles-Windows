# dotfiles-Windows :: repo .gitignore

# Machine-local layers — never commit
powershell/local.ps1
.gitconfig.local
# Local Claude Code state (settings.local.json, session history) stays out of the repo,
# but the committed routine command definitions under .claude/commands/ ARE tracked —
# the claude-routines.yml workflow runs them headless.
.claude/*
!.claude/commands/

# Secrets
*.pem
*.key
*.ppk
.env
.env.*

# Backups created by install.ps1
*.bak
*.*.bak

# OS cruft
Thumbs.db
Desktop.ini
